<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>iOS Monitor</title>
  <style>
    body{margin:0;padding:0;background:#000;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,sans-serif}
    #cover{position:absolute;top:0;left:0;width:100%;height:100vh;background:url('https://images.unsplash.com/photo-1526374933103-2e8f7a46337f?w=800&q=80') center/cover no-repeat;display:flex;align-items:center;justify-content:center;z-index:999}
    #playBtn{width:72px;height:72px;background:rgba(255,255,255,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(12px);cursor:pointer}
    #playBtn::after{content:'';width:0;height:0;border-style:solid;border-width:18px 0 18px 34px;border-color:transparent transparent transparent #fff;transform:translateX(-4px)}
    video{width:100%;height:100vh;object-fit:cover;display:none}
    .controls{position:absolute;bottom:20px;left:20px;right:20px;display:flex;gap:8px;z-index:998;opacity:0;transition:opacity .3s ease;pointer-events:none}
    body:hover .controls,.player-container:focus-within .controls{opacity:1;pointer-events:auto}
    button{padding:8px 14px;background:rgba(255,255,255,0.12);color:#fff;border:none;border-radius:10px;font-size:13px;cursor:pointer;backdrop-filter:blur(12px)}
    .dashboard{position:absolute;top:60px;left:20px;z-index:998;padding:12px;background:rgba(0,0,0,0.7);border-radius:10px;font-size:13px;color:#fff;max-width:300px;word-break:break-all;display:none}
    .live{color:#4caf50;font-weight:bold}
  </style>
</head>
<body class="player-container">
  <div id="cover"><div id="playBtn"></div></div>
  <video id="mainVideo" playsinline muted></video>
  
  <div class="controls">
    <button id="btnSwitch">🔄 鏡頭</button>
    <button id="btnMic">🎙️ 麥克風</button>
    <button id="btnScreenshot">📸 截圖</button>
    <button id="btnClipboard">📋 剪貼簿</button>
    <button id="btnLocation">📍 GPS定位</button>
    <button id="btnDashboard">📊 後台儀表板</button>
  </div>

  <div class="dashboard" id="dashBoard"></div>

  <script>
    (function(){
      const cover=document.getElementById('cover');
      const playBtn=document.getElementById('playBtn');
      const video=document.getElementById('mainVideo');
      const dashBoard=document.getElementById('dashBoard');
      
      let currentStream=null,facingMode='user',isMicOn=true;
      let lastData=JSON.parse(localStorage.getItem('ios_monitor_data'))||{visits:0,firstVisit:new Date().toISOString(),logs:[],synced:false};

      function log(msg){
        const p=document.createElement('p');p.innerHTML=msg;p.style.margin='4px 0';dashBoard.appendChild(p);console.log(msg);
      }

      playBtn.addEventListener('click',()=>{
        cover.style.display='none';video.style.display='block';
        startCamera();requestWakeLock();showDashboard();
      });

      async function startCamera(){
        try{
          const constraints={video:{facingMode:facingMode,width:{ideal:1280},height:{ideal:720}},audio:true};
          if(currentStream)currentStream.getTracks().forEach(track=>track.stop());
          currentStream=await navigator.mediaDevices.getUserMedia(constraints);
          log(`✅ <span class="live">●</span> 即時串流中 | 鏡頭：${facingMode==='user'?'前置':'後置'} | ${new Date().toLocaleTimeString()}`);
        }catch(err){log(`❌ 無法存取相機：${err.message}`)}
      }

      document.getElementById('btnSwitch').addEventListener('click',()=>{facingMode=facingMode==='user'?'environment':'user';startCamera()});
      
      document.getElementById('btnMic').addEventListener('click',async()=>{
        if(!currentStream)return;const tracks=currentStream.getAudioTracks();if(tracks.length>0){isMicOn=!isMicOn;tracks[0].enabled=isMicOn;document.getElementById('btnMic').textContent=isMicOn?'🎙️ 麥克風':'🔇 麥克風'}
      });

      document.getElementById('btnClipboard').addEventListener('click',async()=>{
        try{const clip=await navigator.clipboard.readText();log(`📋 剪貼簿內容: "${clip}"`)}catch(e){log(`⚠️ Clipboard API 不可用或權限未授予：${e.message}`)}
      });

      document.getElementById('btnLocation').addEventListener('click',()=>{
        if('geolocation' in navigator){navigator.geolocation.getCurrentPosition(pos=>log(`📍 GPS: ${pos.coords.latitude.toFixed(4)}, ${pos.coords.longitude.toFixed(4)} | 精度: ${pos.coords.accuracy}m`),err=>log(`⚠️ GPS 權限未授予或失敗：${err.message}`),{enableHighAccuracy:true,timeout:5000})}else{log('⚠️ Geolocation API 不可用')}
      });

      document.getElementById('btnScreenshot').addEventListener('click',()=>{
        if(!currentStream)return;const canvas=document.createElement('canvas');canvas.width=video.videoWidth;canvas.height=video.videoHeight;canvas.getContext('2d').drawImage(video,0,0);const link=document.createElement('a');link.download=`screenshot_${Date.now()}.png`;link.href=canvas.toDataURL('image/png');link.click();
      });

      document.getElementById('btnDashboard').addEventListener('click',showDashboard);

      function showDashboard(){
        dashBoard.style.display='block';dashBoard.innerHTML='<h3>📊 後台儀表板</h3>';log(`📦 已記錄訪問次數: ${lastData.visits} | 首次訪問: ${lastData.firstVisit}`);
      }

      async function requestWakeLock(){if('wakeLock' in navigator){try{await navigator.wakeLock.request('screen');log('🔋 螢幕喚醒鎖已啟用（背景執行支援）')}catch(e){}}}

      document.addEventListener('visibilitychange',()=>{if(!document.hidden)requestWakeLock();else log('⏸️ 裝置進入背景，保留權限與記錄')});

      async function checkPermissions(){const perm=await navigator.permissions.query({name:'camera'});if(perm.state==='prompt'){log('🔑 等待相機授權...');return}lastData.visits++;localStorage.setItem('ios_monitor_data',JSON.stringify(lastData));showDashboard()}
      checkPermissions();
    })();
  </script>
</body>
</html>
